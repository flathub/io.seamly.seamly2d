From 9d693b45cfb6d0f6dfa5fc20bdee9d4546ae256b Mon Sep 17 00:00:00 2001
From: Christoph Settgast <csett86_git@quicksands.de>
Date: Mon, 30 Mar 2026 21:50:44 +0200
Subject: [PATCH] Fix patch to link xerces library for flatpak

---
 src/app/seamly2d/seamly2d.pro | 2 +-
 src/app/seamlyme/seamlyme.pro | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/src/app/seamly2d/seamly2d.pro b/src/app/seamly2d/seamly2d.pro
index ffd93f11c4..5da8cde753 100644
--- a/src/app/seamly2d/seamly2d.pro
+++ b/src/app/seamly2d/seamly2d.pro
@@ -341,7 +341,7 @@ else:unix|win32-g++: PRE_TARGETDEPS += $$OUT_PWD/../../libs/vpropertyexplorer/$$
 
 # xerces library
 macx: LIBS += -L$${PWD}/../../libs/xerces-c/macx/lib -lxerces-c
-else:unix: LIBS += -lxerces-c
+else:unix: LIBS += -L/app/lib -lxerces-c
 win32-msvc: LIBS += -L$${PWD}/../../libs/xerces-c/msvc/lib -lxerces-c_3
 win32-arm64-msvc: LIBS += -L$${PWD}/../../libs/xerces-c/msvc-arm64/lib -lxerces-c_3
 win32-g++: LIBS += -L$${PWD}/../../libs/xerces-c/mingw/lib -lxerces-c
diff --git a/src/app/seamlyme/seamlyme.pro b/src/app/seamlyme/seamlyme.pro
index df4aed6a09..724506a344 100644
--- a/src/app/seamlyme/seamlyme.pro
+++ b/src/app/seamlyme/seamlyme.pro
@@ -227,7 +227,7 @@ else:unix|win32-g++: PRE_TARGETDEPS += $$OUT_PWD/../../libs/vpropertyexplorer/$$
 
 # xerces library
 macx: LIBS += -L$${PWD}/../../libs/xerces-c/macx/lib -lxerces-c
-else:unix: LIBS += -lxerces-c
+else:unix: LIBS += -L/app/lib -lxerces-c
 win32-msvc: LIBS += -L$${PWD}/../../libs/xerces-c/msvc/lib -lxerces-c_3
 win32-arm64-msvc: LIBS += -L$${PWD}/../../libs/xerces-c/msvc-arm64/lib -lxerces-c_3
 win32-g++: LIBS += -L$${PWD}/../../libs/xerces-c/mingw/lib -lxerces-c
